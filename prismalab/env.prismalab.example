PRISMALAB_APP_NAME=PrismaLab

# --- База данных (для продакшена на сервере лучше PostgreSQL/Supabase) ---
# Если DATABASE_URL пустой — используется SQLite (файл PRISMALAB_DB_PATH или prismalab.db).
#
# Подключение Supabase (рекомендуется для сервера):
# 1. supabase.com → твой проект → Project Settings → Database
# 2. Connection string → URI (удобно "Transaction" pooler, порт 6543)
# 3. Вставь пароль БД вместо [YOUR-PASSWORD], скопируй в .env:
#
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[YOUR-PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
#
# Регион и хост в твоём проекте могут отличаться — смотри в Supabase.
DATABASE_URL=

# Telegram
PRISMALAB_BOT_TOKEN=123:abc
# ID владельца (для /tips, Mini App только для owner)
PRISMALAB_OWNER_ID=
# Mini App (HTTPS). Кнопка «Открыть студию» — только для owner
MINIAPP_URL=https://app.prismalab.ru/app

# Бот поддержки (отдельный бот)
PRISMALAB_SUPPORT_BOT_TOKEN=
PRISMALAB_SUPPORT_ADMIN_ID=

# Astria (генерация FaceID/LoRA)
PRISMALAB_ASTRIA_API_KEY=...
# Публичный URL сервера (для webhook Astria pack callback). Если пусто — берётся из MINIAPP_URL.
# PRISMALAB_PUBLIC_URL=https://app.prismalab.ru
# Секрет для HMAC-подписи callback URL (защита от подделки)
# PRISMALAB_ASTRIA_PACK_CALLBACK_SECRET=random_string_here
PRISMALAB_ASTRIA_TUNE_ID=
# Таймаут загрузки 10 фото при создании LoRA (секунды). По умолчанию 600 (10 мин).
# Если ReadTimeout — увеличь до 900.
# PRISMALAB_ASTRIA_LORA_CREATE_TIMEOUT_SECONDS=600

# KIE API (тестирование моделей, опционально)
PRISMALAB_KIE_API_KEY=
# Таймаут ожидания результата KIE/Seedream (секунды). По умолчанию 600 (10 мин).
# Если «Таймаут ожидания результата KIE» — увеличь до 900 или 1200.
# PRISMALAB_KIE_MAX_SECONDS=600

# Сила промпта (0..1)
PRISMALAB_PROMPT_STRENGTH=0.7

# Astria Packs: JSON-массив. Порядок = порядок в приложении. category: female | child | animals
PRISMALAB_ASTRIA_PACK_OFFERS='[{"id":820,"title":"Деловые портреты","price_rub":799,"expected_images":44,"class_name":"woman","category":"female"},{"id":260,"title":"Деловые портреты-2","price_rub":899,"expected_images":56,"class_name":"woman","category":"female"},{"id":1317,"title":"Современный женский образ","price_rub":699,"expected_images":32,"class_name":"woman","category":"female"},{"id":3435,"title":"Классические портреты","price_rub":1399,"expected_images":76,"class_name":"woman","category":"female"},{"id":2159,"title":"Муза пустыни","price_rub":999,"expected_images":56,"class_name":"woman","category":"female"},{"id":3605,"title":"Интерьерная коллекция","price_rub":1499,"expected_images":90,"class_name":"woman","category":"female"},{"id":3576,"title":"Блеск и бизнес","price_rub":1599,"expected_images":94,"class_name":"woman","category":"female"},{"id":3562,"title":"Драматичная мода в чёрном","price_rub":1499,"expected_images":88,"class_name":"woman","category":"female"},{"id":1534,"title":"Обложка модельного агентства","price_rub":1399,"expected_images":72,"class_name":"woman","category":"female"},{"id":1511,"title":"Идеальные фото для знакомств","price_rub":1599,"expected_images":90,"class_name":"woman","category":"female"},{"id":266,"title":"Фото, которые притягивают","price_rub":599,"expected_images":29,"class_name":"woman","category":"female"},{"id":3456,"title":"Элегантность в чёрном","price_rub":1599,"expected_images":98,"class_name":"woman","category":"female"},{"id":2259,"title":"Сияющая сказка","price_rub":1299,"expected_images":68,"class_name":"woman","category":"female"},{"id":2576,"title":"Богемная фантазия в джунглях","price_rub":799,"expected_images":44,"class_name":"woman","category":"female"},{"id":538,"title":"Уэнсдей Аддамс","price_rub":499,"expected_images":11,"class_name":"woman","category":"female"},{"id":264,"title":"Мифические персонажи","price_rub":499,"expected_images":16,"class_name":"woman","category":"female"},{"id":2156,"title":"Студия Нуар","price_rub":799,"expected_images":48,"class_name":"woman","category":"female"},{"id":884,"title":"Инстаграм","price_rub":599,"expected_images":20,"class_name":"woman","category":"female"},{"id":236,"title":"Игра престолов","price_rub":499,"expected_images":10,"class_name":"woman","category":"female"},{"id":3570,"title":"Двойная экспозиция","price_rub":899,"expected_images":52,"class_name":"woman","category":"female"},{"id":268,"title":"Утончённый гламур","price_rub":499,"expected_images":16,"class_name":"woman","category":"female"},{"id":551,"title":"Домашние образы","price_rub":499,"expected_images":12,"class_name":"woman","category":"female"},{"id":623,"title":"Красная дорожка","price_rub":599,"expected_images":25,"class_name":"woman","category":"female"},{"id":821,"title":"Студийная съёмка","price_rub":599,"expected_images":24,"class_name":"woman","category":"female"},{"id":3161,"title":"Портрет художника","price_rub":899,"expected_images":52,"class_name":"woman","category":"female"},{"id":2530,"title":"В стиле поп-арт","price_rub":899,"expected_images":52,"class_name":"woman","category":"female"},{"id":902,"title":"Сказочная страна","price_rub":599,"expected_images":20,"class_name":"woman","category":"female"},{"id":265,"title":"Барби","price_rub":499,"expected_images":14,"class_name":"woman","category":"female"},{"id":589,"title":"Яркие эмоции","price_rub":599,"expected_images":20,"class_name":"woman","category":"female"},{"id":888,"title":"Примерка мэйкапа","price_rub":599,"expected_images":20,"class_name":"woman","category":"female"},{"id":895,"title":"Радужная эстетика","price_rub":599,"expected_images":20,"class_name":"woman","category":"female"},{"id":893,"title":"Гармония в каждом кадре","price_rub":599,"expected_images":20,"class_name":"woman","category":"female"},{"id":863,"title":"Zara","price_rub":599,"expected_images":22,"class_name":"woman","category":"female"}]'
# Режим class name для обучения Персоны: person (по умолчанию, как раньше) или gender (man/woman)
# PRISMALAB_PERSONA_LORA_NAME_MODE=person

# Telegram Payments (инвойс в боте). Приоритет над ЮKassa.
# TELEGRAM_PROVIDER_TOKEN=...  # из BotFather → Payments → ЮKassa
# INVOICE_AMOUNT_KOPECKS=8800  # 88 руб (минимум Telegram для RUB). Потом — реальные суммы

# ЮKassa (оплата по ссылке, если нет TELEGRAM_PROVIDER_TOKEN)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
# Тест: все платежи по 10 руб. 0 = реальные цены
# PAYMENT_TEST_AMOUNT=10
# Только для dev: запуск паков без оплаты (удобно для интеграционного теста)
# PRISMALAB_DEV_SKIP_PACK_PAYMENT=true
# Только для dev: запуск паков через новую загрузку 10 фото (без tune_ids)
# PRISMALAB_DEV_PACKS_TRAIN_FROM_IMAGES=true
# URL для возврата после оплаты (опционально, иначе берётся t.me/username бота автоматически)
# YOOKASSA_RETURN_URL=https://t.me/your_bot
YOOKASSA_WEBHOOK_PORT=8080
